      advice: '在依赖贵人帮助的同时，也要培养独立性',
      strength: '善良正直，学识渊博，贵人多助',
      weakness: '依赖性强，缺乏主见，容易被人利用'
    }
  };
  
  return details[shiShenName] || null;
}

